# ──────────────────────────────────────────────────────────────────────────────
# GiftAgent server env. Copy to `.env` and fill in. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────────────────────

# --- Server ---
PORT=4000
# CORS: the Vite dev origin is allowed by default; set PROD_ORIGIN for deploys.
VITE_DEV_ORIGIN=http://localhost:5173
PROD_ORIGIN=

# --- Privy (server-side access-token verification) ---
# From the Privy dashboard. The secret must stay server-side only.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Supabase (server-side, service-role key — bypasses RLS, server only) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Anthropic (used by the AI agent in a later phase; documented now) ---
ANTHROPIC_API_KEY=

# --- Coinbase CDP (mainnet x402 facilitator / wallet ops in later phases) ---
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# --- x402 / chain config ---
# Facilitator used by our TEST SELLER (scripts/test-seller.ts) to verify+settle.
# Base Sepolia testnet facilitator (no auth required):
FACILITATOR_URL=https://x402.org/facilitator
# JSON-RPC endpoint for onchain reads (enables x402 gas-sponsoring extensions).
BASE_RPC_URL=https://sepolia.base.org

# --- x402 keystone test script (scripts/x402-test.ts) ---
# Plain EVM private key used ONLY by the test script as the payer.
# Replaced by Privy delegated signing in a later phase. Fund with test/real USDC.
TEST_PRIVATE_KEY=
# Step A (testnet) resource server — the local test seller from scripts/test-seller.ts:
X402_TEST_URL=http://localhost:4021/weather
# Step B (mainnet) real service — a real agentic.market x402 endpoint:
X402_MAINNET_URL=
# Network override for the real call (CAIP-2): Base mainnet = eip155:8453
X402_MAINNET_NETWORK=eip155:8453

# ──────────────────────────────────────────────────────────────────────────────
# Frontend (Vite) env — set these in /react/.env (Vite only exposes VITE_*):
#   VITE_PRIVY_APP_ID  = same value as PRIVY_APP_ID above (public, app id only)
#   VITE_API_URL       = http://localhost:4000  (the server base URL)
# ──────────────────────────────────────────────────────────────────────────────
