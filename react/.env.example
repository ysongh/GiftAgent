# Vite frontend env. Copy to `react/.env`. Only VITE_* vars are exposed to the bundle.
# Never put secrets here — this ships to the browser.

# Privy app id (public — the app id only, NOT the app secret).
VITE_PRIVY_APP_ID=

# Base URL of the GiftAgent server.
VITE_API_URL=http://localhost:4000

# Privy authorization key id (public id, NOT the private key). Used to add the app's
# key as a session signer on the user's TEE wallet (Phase 2 agent). Same value as the
# server's PRIVY_AUTHORIZATION_KEY_ID.
VITE_PRIVY_AUTHORIZATION_KEY_ID=
